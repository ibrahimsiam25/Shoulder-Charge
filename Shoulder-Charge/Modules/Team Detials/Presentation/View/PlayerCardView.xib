                        <constraint firstItem="playerImage" firstAttribute="leading" secondItem="borderContainer" secondAttribute="leading" constant="2" id="img2"/>
                        <constraint firstAttribute="trailing" secondItem="playerImage" secondAttribute="trailing" constant="2" id="img3"/>
                        <constraint firstAttribute="bottom" secondItem="playerImage" secondAttribute="bottom" constant="2" id="img4"/>
                        <constraint firstItem="numberLabel" firstAttribute="top" secondItem="borderContainer" secondAttribute="top" constant="-5" id="num1"/>
                        <constraint firstAttribute="trailing" secondItem="numberLabel" secondAttribute="trailing" constant="-5" id="num2"/>
                    </constraints>
                </view>
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" text="PLAYER NAME" textAlignment="center" lineBreakMode="tailTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="nameLabel" userLabel="Name Label">
                    <rect key="frame" x="2" y="79" width="92" height="12"/>
                    <fontDescription key="fontDescription" type="boldSystem" pointSize="9"/>
                    <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                </label>
