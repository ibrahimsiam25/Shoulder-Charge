                <constraint firstItem="borderContainer" firstAttribute="width" secondItem="contentView" secondAttribute="width" multiplier="0.72" id="c2-width"/>
                <constraint firstItem="borderContainer" firstAttribute="height" secondItem="contentView" secondAttribute="width" multiplier="0.72" id="c2-height"/>
